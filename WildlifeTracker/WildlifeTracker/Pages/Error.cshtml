@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="container py-5 text-center">

    <h1 class="text-danger">Възникна грешка</h1>

    <p class="text-muted">
        Съжаляваме, възникна проблем при обработката на заявката.
    </p>

@if (ViewBag.Message != null)
{
        <p class="fw-semibold">@ViewBag.Message</p>
}

    <a href="/" class="btn btn-primary mt-3">
        Към началната страница
    </a>

</div>
