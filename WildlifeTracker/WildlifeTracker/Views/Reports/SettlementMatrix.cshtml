@model WildlifeTracker.ViewModels.Reports.SettlementMatrixVm
@{
    ViewData["Title"] = "Брой животни по населени места";
}

<div class="container py-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                <div>
                    <h1 class="h3 mb-1">@ViewData["Title"]</h1>
                    <p class="text-muted mb-0">
                        Справка за популацията по населени места и видове за избрана година.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-12 col-md-4 col-lg-3">
                    <label class="form-label fw-semibold">Година</label>
                    <select name="year" class="form-select" asp-items="Model.YearOptions"></select>
                </div>

                <div class="col-12 col-md-auto">
                    <button class="btn text-white px-4" type="submit" style="background-color:#1B5E20;">
                        Покажи
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-0 pt-4 pb-0">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <h2 class="h5 mb-1">Популационна матрица</h2>
                    <p class="text-muted mb-0">Година: <strong>@Model.Year</strong></p>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <span class="badge rounded-pill text-bg-light">Населени места: @Model.Rows.Count</span>
                    <span class="badge rounded-pill text-bg-light">Видове: @Model.SpeciesHeaders.Count</span>
                </div>
            </div>
        </div>

        <div class="card-body">
            <div class="d-flex justify-content-between align-items-end flex-wrap mb-3">
                <div class="d-flex align-items-end gap-3 flex-wrap">
                    <div>
                        <label for="settlementSearch" class="form-label fw-semibold">Търсене по населено място</label>
                        <input type="text"
                               id="settlementSearch"
                               class="form-control"
                               placeholder="Въведете име..."
                               style="width:260px;">
                    </div>

                    <div class="small text-muted pb-1">
                        Показани редове: <span id="visibleRowsCount">@Model.Rows.Count</span>
                    </div>
                </div>

                <div class="d-flex gap-2 small flex-wrap">
                    <span class="badge text-dark" style="background-color:#f8f9fa;">Няма данни</span>
                    <span class="badge text-dark" style="background-color:#d1e7dd;">Ниска стойност</span>
                    <span class="badge text-dark" style="background-color:#75b798;">Средна стойност</span>
                    <span class="badge text-white" style="background-color:#1B5E20;">Висока стойност</span>
                </div>

            </div>


                <table class="table table-bordered table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="fw-semibold">Населено място</th>
                            @foreach (var h in Model.SpeciesHeaders)
                            {
                                <th class="text-center fw-semibold">@h</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Rows)
                        {
                            <tr class="settlement-row" data-settlement="@r.SettlementName.ToLower()">
                                <td class="fw-semibold bg-light">@r.SettlementName</td>

                                @foreach (var c in r.Cells)
                                {
                                    if (!int.TryParse(c, out var value) || value == 0)
                                    {
                                        <td class="text-center text-muted bg-light">-</td>
                                    }
                                    else
                                    {
                                        var bgColor = "";
                                        var textColor = "text-dark";

                                        if (value == 0)
                                        {
                                            bgColor = "#f8f9fa";
                                        }
                                        else if (value <= 50)
                                        {
                                            bgColor = "#d1e7dd";
                                        }
                                        else if (value <= 100)
                                        {
                                            bgColor = "#75b798";
                                        }
                                        else
                                        {
                                            bgColor = "#1B5E20";
                                            textColor = "text-white";
                                        }

                                        <td class="text-center fw-semibold @textColor" style="background-color:@bgColor;">
                                            @value
                                        </td>
                                    }
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const searchInput = document.getElementById("settlementSearch");
            const rows = document.querySelectorAll(".settlement-row");
            const visibleRowsCount = document.getElementById("visibleRowsCount");

            function filterRows() {
                const query = searchInput.value.trim().toLowerCase();
                let visibleCount = 0;

                rows.forEach(row => {
                    const settlementName = row.getAttribute("data-settlement");

                    if (settlementName.includes(query)) {
                        row.style.display = "";
                        visibleCount++;
                    } else {
                        row.style.display = "none";
                    }
                });

                visibleRowsCount.textContent = visibleCount;
            }

            searchInput.addEventListener("input", filterRows);
        });
    </script>
}