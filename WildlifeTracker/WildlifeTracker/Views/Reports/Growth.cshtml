@model WildlifeTracker.ViewModels.Reports.GrowthVm
@{
    ViewData["Title"] = "Процентен ръст спрямо миналата година";
}

<div class="container py-4">

    <div class="mb-4">
        <h1 class="h3 mb-1">@ViewData["Title"]</h1>
        <p class="text-muted mb-0">
            Сравнение на числеността на избран вид в населено място спрямо предходната година.
        </p>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">

                <div class="col-md-2">
                    <label class="form-label fw-semibold">Година</label>
                    <select name="year" class="form-select" asp-items="Model.YearOptions"></select>
                </div>

                <div class="col-md-5">
                    <label class="form-label fw-semibold">Населено място</label>
                    <select name="settlementId" class="form-select" asp-items="Model.SettlementOptions">
                        <option value="">-- изберете --</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-semibold">Вид животно</label>
                    <select name="speciesId" class="form-select" asp-items="Model.SpeciesOptions">
                        <option value="">-- изберете --</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <button class="btn text-white w-100"
                            style="background-color:#1B5E20;">
                        Покажи
                    </button>
                </div>

            </form>
        </div>
    </div>

    @if (Model.SettlementId == null && Model.SpeciesId == null)
    {
        <div class="alert alert-secondary">
            Изберете <strong>населено място</strong> и <strong>вид животно</strong>, за да видите резултата.
        </div>
    }
    else if (Model.SettlementId == null)
    {
        <div class="alert alert-warning">
            Моля, изберете <strong>населено място</strong>.
        </div>
    }
    else if (Model.SpeciesId == null)
    {
        <div class="alert alert-warning">
            Моля, изберете <strong>вид животно</strong>.
        </div>
    }
    else
    {
        var isNoBase = Model.PercentChange == null;
        var percent = isNoBase ? 0 : Model.PercentChange.Value;

        var absPercent = Math.Abs(percent);
        var visualPercent = (double)Math.Min(absPercent, 100) / 2.0;

        var isPositive = percent >= 0;

        var progressClass = isNoBase
        ? "bg-secondary"
        : isPositive ? "bg-success" : "bg-danger";

        <div class="card shadow-sm border-0">
            <div class="card-body">

                <h5 class="card-title mb-3">Резултат</h5>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <div><strong>Населено място:</strong> @Model.SettlementName</div>
                    </div>
                    <div class="col-md-6">
                        <div><strong>Вид:</strong> @Model.SpeciesName</div>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="p-3 border rounded bg-light">
                            <div class="text-muted small">Предходна година (@(Model.Year - 1))</div>
                            <div class="fs-4 fw-bold">@Model.PreviousCount</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="p-3 border rounded bg-light">
                            <div class="text-muted small">Текуща година (@Model.Year)</div>
                            <div class="fs-4 fw-bold">@Model.CurrentCount</div>
                        </div>
                    </div>
                </div>

                @if (isNoBase)
                {
                    <div class="alert alert-secondary mb-0">
                        Не може да бъде изчислен процент на промяна, защото стойността за
                        <strong>@(Model.Year - 1)</strong> е <strong>0</strong>.
                    </div>
                }
                else
                {
                    <div class="mb-2 d-flex justify-content-between">
                        <span class="fw-semibold">Промяна спрямо предходната година</span>
                        <span class="fw-semibold @(isPositive ? "text-success" : "text-danger")">
                            @Model.PercentChange.Value.ToString("0.##") %
                        </span>
                    </div>

                    <div class="position-relative" style="height:28px;">

                        <div class="progress" style="height:28px;">
                            <div class="progress-bar bg-light w-100"></div>
                        </div>

                        <div style="
                position:absolute;
                left:50%;
                top:0;
                bottom:0;
                width:2px;
                background:#343a40;">
                        </div>

                        @if (isPositive)
                        {
                            <div class="progress-bar bg-success progress-animated"
                                 style="
                             position:absolute;
                             left:50%;
                             top:0;
                             height:100%;
                             width:0%;
                             transition:width 1.2s ease-in-out;"
                                 data-width="@visualPercent.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                            </div>
                        }
                        else
                        {
                            <div class="progress-bar bg-danger progress-animated"
                                 style="
                             position:absolute;
                             right:50%;
                             top:0;
                             height:100%;
                             width:0%;
                             transition:width 1.2s ease-in-out;"
                                 data-width="@visualPercent.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                            </div>
                        }

                    </div>

                    <div class="d-flex justify-content-between small text-muted mt-1">
                        <span>Спад</span>
                        <span>0%</span>
                        <span>Ръст</span>
                    </div>

                    <div class="mt-3">
                        @if (isPositive)
                        {
                            <div class="alert alert-success mb-0">
                                Популацията е <strong>нараснала</strong> с
                                <strong>@Model.PercentChange.Value.ToString("0.##")%</strong>
                                спрямо предходната година.
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-danger mb-0">
                                Популацията е <strong>намаляла</strong> с
                                <strong>@Math.Abs(Model.PercentChange.Value).ToString("0.##")%</strong>
                                спрямо предходната година.
                            </div>
                        }
                    </div>
                }

            </div>
        </div>
    }

</div>

@section Scripts {
    <script>
                document.addEventListener("DOMContentLoaded", function () {

            const bars = document.querySelectorAll(".progress-animated");

            setTimeout(() => {
                bars.forEach(bar => {
                    const target = bar.getAttribute("data-width");
                    bar.style.width = target + "%";
                });
            }, 200);

        });
    </script>
}